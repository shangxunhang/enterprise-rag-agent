# App
APP_NAME=agent-rag-system
APP_ENV=dev

# Data paths
DATA_ROOT=data
RUN_TRACE_DIR=data/runs
DATA_CAPTURE_DIR=data/captures
EVAL_OUTPUT_DIR=data/eval_outputs
TASK_STATE_DIR=data/tasks

# Prompt
PROMPT_ROOT=prompts
DEFAULT_SCHEME_PROMPT_ID=scheme_section_generation_v1

# Runtime switches
TRACE_ENABLED=true
DATA_CAPTURE_ENABLED=true
ENABLE_LLM_ROUTING=true

# Model selection
DEFAULT_MODEL_NAME=local_qwen2_5_7b_gptq_int4
SUPERVISOR_MODEL_NAME=local_qwen2_5_7b_gptq_int4

# Local Qwen model
LOCAL_QWEN_MODEL_NAME=local_qwen2_5_7b_gptq_int4
LOCAL_QWEN_MODEL_PATH=path/to/Qwen2.5-7B-Instruct-GPTQ-Int4
LOCAL_QWEN_DEVICE=cuda
LOCAL_QWEN_MAX_NEW_TOKENS=512

# Semantic soft gate
ENABLE_SEMANTIC_GATE=false
SEMANTIC_GATE_MODEL_NAME=local_qwen2_5_7b_gptq_int4

# Evaluation
MIN_EVAL_OUTPUT_CHARS=100
