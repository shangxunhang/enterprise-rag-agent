# App
APP_NAME=agent-rag-system
APP_ENV=dev

# Data paths (all runtime subdirectories are derived from DATA_ROOT)
DATA_ROOT=data

# Prompt
PROMPT_ROOT=prompts
DEFAULT_SCHEME_PROMPT_ID=scheme_section_generation_v1

# Runtime switches
TRACE_ENABLED=true
DATA_CAPTURE_ENABLED=true
ENABLE_LLM_ROUTING=true

# Model selection
DEFAULT_MODEL_NAME=local_qwen2_5_1_5b
SUPERVISOR_MODEL_NAME=local_qwen2_5_1_5b

# Local Qwen compatibility alias + multi-model profiles
LOCAL_QWEN_MODEL_NAME=local_qwen2_5_1_5b
LOCAL_QWEN_MODEL_PATH=D:\models\huggingface\llm\Qwen2.5-1.5B-Instruct
LOCAL_QWEN_DEVICE=cuda
LOCAL_QWEN_MAX_NEW_TOKENS=1536
LOCAL_QWEN_1_5B_MODEL_NAME=local_qwen2_5_1_5b
LOCAL_QWEN_1_5B_MODEL_PATH=D:\models\huggingface\llm\Qwen2.5-1.5B-Instruct
LOCAL_QWEN_3B_MODEL_NAME=local_qwen2_5_3b
LOCAL_QWEN_3B_MODEL_PATH=D:\models\huggingface\llm\Qwen2.5-3B-Instruct
LOCAL_QWEN_7B_MODEL_NAME=local_qwen2_5_7b_gptq_int4
LOCAL_QWEN_7B_MODEL_PATH=D:\models\huggingface\llm\Qwen2.5-7B-Instruct-GPTQ-Int4

# DeepSeek / OpenAI-compatible provider
DEEPSEEK_MODEL_NAME=deepseek_api
DEEPSEEK_PROVIDER_MODEL_NAME=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

# Semantic soft gate
ENABLE_SEMANTIC_GATE=false
SEMANTIC_GATE_MODEL_NAME=local_qwen2_5_1_5b

# Evaluation
MIN_EVAL_OUTPUT_CHARS=100
